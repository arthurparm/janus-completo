{
  "$schema": "https://angular.io/schemas/ngsw-config/1.0",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/favicon.ico",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/public/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-performance",
      "urls": [
        "/api/**",
        "/healthz"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "10m",
        "strategy": "freshness",
        "timeout": "5s"
      }
    }
  ]
}
