NEO4J_USER=neo4j
NEO4J_PASSWORD=troque-neo4j
NEO4J_HEAP_INITIAL=2G
NEO4J_HEAP_MAX=8G
NEO4J_PAGECACHE=8G

# Qdrant sem API key por padrao (acesso restrito via Tailscale/firewall).
# Para reativar auth futuramente:
# QDRANT_API_KEY=troque-qdrant-api-key

OLLAMA_ORCHESTRATOR_MODEL=gpt-oss:20b
OLLAMA_CODER_MODEL=deepseek-coder:6.7b
OLLAMA_CURATOR_MODEL=ministral-3:14b
OLLAMA_KEEP_ALIVE=120m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=128
