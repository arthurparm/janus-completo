# Core
ENVIRONMENT=production
AUTH_JWT_SECRET=troque-por-um-segredo-forte
CORS_ALLOW_ORIGINS=["http://SEU_IP_OU_DOMINIO:4300","http://localhost:4300"]

# Local services on 16GB machine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=janus
POSTGRES_PASSWORD=troque-postgres
POSTGRES_DB=janus_db

REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=janus
RABBITMQ_PASSWORD=troque-rabbitmq

# Remote heavy services (64GB machine via Tailscale IP)
# Use o IP Tailscale da maquina forte (formato comum: 100.x.y.z)
NEO4J_URI=bolt://100.88.71.49:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=troque-neo4j

QDRANT_HOST=100.88.71.49
QDRANT_PORT=6333
QDRANT_API_KEY=

OLLAMA_HOST=http://100.88.71.49:11434
OLLAMA_ORCHESTRATOR_MODEL=gpt-oss:20b
OLLAMA_CODER_MODEL=deepseek-coder:6.7b
OLLAMA_CURATOR_MODEL=ministral-3:14b

# Optional cloud LLMs (recommended fallback)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
OPENAI_MODEL_NAME=gpt-5-mini
DEEPSEEK_MODEL_NAME=deepseek-chat
XAI_MODEL_NAME=grok-4-1-fast-reasoning

# Startup behavior
START_ORCHESTRATOR_WORKERS_ON_STARTUP=true
AUTO_INDEX_ON_STARTUP=true
