# Repository-wide .gitignore (Janus monorepo: Python backend + Angular frontend)

# -----------------------------
# OS / file explorer noise
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------
# Editors / IDEs
# -----------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.swp
*.swo

# -----------------------------
# Logs
# -----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
copilot-messages.log
backend.log
backend/backend.log
backend/app/backend.log

# -----------------------------
# Environment / secrets (local only)
# -----------------------------
.env
frontend/.env
backend/app/.env
backend/app/.env.windows
backend/config/.env
backend/.env*
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
backend/app/serviceAccountKey.json
backend/observability/alertmanager/alertmanager.local.yml

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.py,cover
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
backend/.venv/

# -----------------------------
# Node / Angular
# -----------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/cache/
frontend/coverage/
frontend/.sass-cache/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
*.tsbuildinfo

# -----------------------------
# Build / packaging artifacts
# -----------------------------
dist/
build/
site/
*.egg-info/
pip-wheel-metadata/
*.whl
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# -----------------------------
# Local runtime/workspace data
# -----------------------------
.project/*.sqlite
.project/*.sqlite-wal
.project/*.sqlite-shm
.project/complete_drafts.txt
.project/localProjectSettings.json
.project/attachments/files/**
backend/data/
backend/workspace/
.claude/worktrees/
_bmad/

# -----------------------------
# Temporary artifacts
# -----------------------------
coverage/
outputs/tmp/
outputs/backups/
backend/evals/technical-qa/runs/
evidencia.txt
