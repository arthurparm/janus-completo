# Repository-wide .gitignore (Janus monorepo: Python backend + Angular frontend)

# -----------------------------
# OS / file explorer noise
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------
# Editors / IDEs
# -----------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.swp
*.swo

# -----------------------------
# Logs
# -----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
copilot-messages.log
janus.log
janus/janus.log
janus/app/janus.log

# -----------------------------
# Environment / secrets (local only)
# -----------------------------
front/.env
janus/app/.env
janus/app/.env.windows
janus/config/.env
janus/.env*
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
janus/app/serviceAccountKey.json

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.py,cover
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
janus/.venv/

# -----------------------------
# Node / Angular
# -----------------------------
node_modules/
front/node_modules/
front/dist/
front/.angular/cache/
front/coverage/
front/.sass-cache/
front/tmp/
front/out-tsc/
front/bazel-out/
*.tsbuildinfo

# -----------------------------
# Build / packaging artifacts
# -----------------------------
dist/
build/
site/
*.egg-info/
pip-wheel-metadata/
*.whl
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# -----------------------------
# Local runtime/workspace data
# -----------------------------
.project/*.sqlite
.project/*.sqlite-wal
.project/*.sqlite-shm
.project/complete_drafts.txt
.project/localProjectSettings.json
.project/attachments/files/**
janus/data/
janus/workspace/
.claude/worktrees/
_bmad/

# -----------------------------
# Temporary artifacts
# -----------------------------
coverage/
artifacts/tmp/
janus/evals/technical-qa/runs/
