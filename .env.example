# =================================================================
# Exemplo de configuração para o Projeto Janus
# Copie este arquivo para .env e preencha as variáveis necessárias.
# =================================================================

# --- Configurações da Aplicação ---
APP_NAME=Janus
APP_VERSION=0.1.8.6
ENVIRONMENT=development # 'development' ou 'production'
DRY_RUN=false # Se true, algumas operações (como escrita de arquivos) serão simuladas

# --- Banco de Dados de Grafo (Neo4j) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password # Mude esta senha em produção!

# --- Banco de Dados Vetorial (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# QDRANT_API_KEY= # Opcional, necessário para Qdrant Cloud

# --- Provedores de LLM (Preencha apenas os que for usar) ---

# OpenAI (Nuvem)
# OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o

# Google Gemini (Nuvem) - Veja GEMINI.md para mais detalhes
# GEMINI_API_KEY=AIza...
GEMINI_MODEL_NAME=gemini-1.5-pro-latest

# Ollama (Local - Cérebro Soberano)
OLLAMA_HOST=http://ollama:11434
OLLAMA_ORCHESTRATOR_MODEL=llama3.1:8b
OLLAMA_CODER_MODEL=codellama:7b
OLLAMA_CURATOR_MODEL=phi3:mini

# --- Limites de Taxa da API (Opcional) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_IP_PER_MIN=60
RATE_LIMIT_PER_KEY_PER_MIN=300 # Se você implementar chaves de API por cliente