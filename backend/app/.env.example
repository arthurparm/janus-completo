# Backend + local infra bootstrap template (development)
# Copy to backend/app/.env and adjust secrets before real use.

ENVIRONMENT=development

# Auth
AUTH_JWT_SECRET=__REQUIRED__
AUTH_JWT_EXPIRES_SECONDS=3600

# Postgres (used by compose + backend)
POSTGRES_USER=janus
POSTGRES_PASSWORD=__REQUIRED__
POSTGRES_DB=janus_db

# RabbitMQ (used by compose + management API scripts)
RABBITMQ_USER=janus
RABBITMQ_PASSWORD=__REQUIRED__

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=__REQUIRED__
NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

# Grafana local admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__REQUIRED__

# Optional cloud providers (leave empty for local/Ollama fallback)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=

# Frontend/root concern (do not store here by default):
# VITE_SUPABASE_ANON_KEY=
