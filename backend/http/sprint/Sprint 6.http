# @name s6_llm_providers
GET {{host}}{{api_v1_prefix}}/llm/providers
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

