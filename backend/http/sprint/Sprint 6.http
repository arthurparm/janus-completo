# - [Evaluation] POST /api/v1/evaluation/experiments/{experiment_id}/results
# - [Evaluation] GET /api/v1/evaluation/experiments/{experiment_id}/winner
# - [LLM] POST /api/v1/llm/ab/set-experiment
# - [LLM] GET /api/v1/llm/budget/summary
# - [LLM] POST /api/v1/llm/cache/invalidate
# - [LLM] GET /api/v1/llm/cache/status
# - [LLM] GET /api/v1/llm/circuit-breakers
# - [LLM] POST /api/v1/llm/circuit-breakers/{provider}/reset
