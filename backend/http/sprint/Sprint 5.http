###
    # SPRINT 5: Auto-Otimizacao e Supervisao (Optimization + Meta-Agent)
    # Fluxos E2E reais + cobertura complementar de endpoints da sprint
    # Modulos: Optimization, Meta-Agent
    ###

    @host = http://localhost:8000
@api_v1_prefix = /api/v1
@token = 
@admin_token = 
@correlation_id = {{$timestamp}}
@client_version = 2.0.0
@actor_user_id = 1
@user_id_int = 1
@user_id_str = 1
@target_user_id = 1
@conversation_id = conv-placeholder
@message_id = msg-placeholder
@goal_id = goal-placeholder
@run_id = 1
@task_id = task-placeholder
@agent_id = agent-placeholder
@doc_id = doc-placeholder
@experiment_id = 1
@arm_id = 1
@model_id = demo-model
@request_id = req-demo
@action_id = 1
@consent_id = 1
@queue_name = janus.knowledge.consolidation
@queue_name_missing = default


############################################
# 0) Preflight de autenticacao
############################################
# @name auth_local_me_preflight
GET {{host}}{{api_v1_prefix}}/auth/local/me
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Preflight auth/local/me: 200 e JSON", function() {
  client.assert(response.status === 200, "Forneca @token valido (auth/local/me != 200)");
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
try {
  const body = response.body.json();
  if (body && body.id) client.global.set("actor_user_id", String(body.id));
} catch (e) {}
%}
############################################
# Indice de endpoints cobertos nesta sprint
############################################
# - [Meta-Agent] POST /api/v1/meta-agent/analyze
# - [Meta-Agent] GET /api/v1/meta-agent/health
# - [Meta-Agent] POST /api/v1/meta-agent/heartbeat/start
# - [Meta-Agent] GET /api/v1/meta-agent/heartbeat/status
# - [Meta-Agent] POST /api/v1/meta-agent/heartbeat/stop
# - [Meta-Agent] GET /api/v1/meta-agent/report/latest
# - [Optimization] POST /api/v1/optimization/analyze
# - [Optimization] GET /api/v1/optimization/health
# - [Optimization] GET /api/v1/optimization/issues
# - [Optimization] GET /api/v1/optimization/metrics/history
# - [Optimization] POST /api/v1/optimization/run-cycle
# - [Optimization] GET /api/v1/optimization/status

############################################
# 1) Optimization + Meta-Agent (happy path)
############################################
# @name s5_optimization_health
GET {{host}}{{api_v1_prefix}}/optimization/health
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("optimization/health: 200", function() { client.assert(response.status === 200); }); %}

###
# @name s5_optimization_analyze
POST {{host}}{{api_v1_prefix}}/optimization/analyze?analysis_type=performance&detailed=true
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("optimization/analyze: 200", function() { client.assert(response.status === 200); }); %}

