###
# SPRINT 2: Memória Episódica (Qdrant)
# Testes completos de armazenamento e recuperação de experiências
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Adicionar Experiência na Memória - Sucesso com Ferramenta
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "action_success",
  "content": "Executei com sucesso a ferramenta search_web para buscar informações sobre Python",
  "metadata": {
    "tool_used": "search_web",
    "query": "Python tutorial",
    "result_count": 5
  }
}

###
# 2. Adicionar Experiência de Erro
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "action_failure",
  "content": "Falha ao executar write_file: permissão negada no diretório /root",
  "metadata": {
    "tool_used": "write_file",
    "error_type": "PermissionError",
    "severity": "high"
  }
}

###
# 3. Adicionar Experiência de Aprendizado
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "lesson_learned",
  "content": "Aprendi que ao usar execute_python_code, devo sempre validar a sintaxe antes de executar para evitar SyntaxError",
  "metadata": {
    "context": "reflexion",
    "iteration": 3
  }
}

###
# 4. Adicionar Experiência de Raciocínio
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "reasoning",
  "content": "Planejei a solução dividindo o problema em 3 etapas: análise, processamento e validação",
  "metadata": {
    "reasoning_type": "plan",
    "steps": 3
  }
}

###
# 5. Adicionar Experiência de Cálculo
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "action_success",
  "content": "Calculei com sucesso a média de [10, 20, 30, 40, 50] resultando em 30.0",
  "metadata": {
    "tool_used": "execute_python_expression",
    "operation": "mean"
  }
}

###
# 6. Adicionar Experiência de Reflexion
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "reflexion_iteration",
  "content": "Após revisar minha abordagem, identifiquei que posso otimizar usando caching para reduzir chamadas repetidas",
  "metadata": {
    "iteration": 2,
    "score": 0.85
  }
}

###
# 7. Buscar Experiências Relacionadas a "Python"
GET {{host}}{{api_v1_prefix}}/memory/recall?query=Python
Accept: application/json

###
# 8. Buscar Experiências de Falhas e Erros
GET {{host}}{{api_v1_prefix}}/memory/recall?query=falha%20erro%20problema
Accept: application/json

###
# 9. Buscar Experiências de Sucesso com Ferramentas
GET {{host}}{{api_v1_prefix}}/memory/recall?query=ferramenta%20sucesso%20executei
Accept: application/json

###
# 10. Buscar Experiências de Aprendizado
GET {{host}}{{api_v1_prefix}}/memory/recall?query=aprendi%20lição
Accept: application/json

###
# 11. Buscar Experiências de Reflexion
GET {{host}}{{api_v1_prefix}}/memory/recall?query=reflexion%20otimizar
Accept: application/json

###
# 12. Buscar Experiências Genéricas
GET {{host}}{{api_v1_prefix}}/memory/recall?query=experiência
Accept: application/json

###
# 13. Adicionar Experiência de Multi-Agent Collaboration
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "collaboration",
  "content": "Coordenei com sucesso 3 agentes especializados para resolver tarefa complexa de análise de dados",
  "metadata": {
    "agents": [
      "data_analyst",
      "code_executor",
      "validator"
    ],
    "task_type": "data_analysis",
    "duration_seconds": 45
  }
}

###
# 14. Adicionar Experiência de Meta-Agent
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "meta_optimization",
  "content": "Meta-agente identificou padrão de falhas repetitivas em operações de arquivo e sugeriu implementação de retry automático",
  "metadata": {
    "pattern": "file_operation_failures",
    "suggestion": "implement_auto_retry",
    "confidence": 0.92
  }
}

###
# 15. Buscar Todas as Experiências Recentes
GET {{host}}{{api_v1_prefix}}/memory/recall?query=agente%20sistema
Accept: application/json

###
# 16. Adicionar Experiência com Metadados Complexos
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "neural_training",
  "content": "Treinamento do modelo de classificação completado com acurácia de 87% após 5 épocas",
  "metadata": {
    "model_name": "intent_classifier_v1",
    "accuracy": 0.87,
    "epochs": 5,
    "training_samples": 1000,
    "validation_samples": 200,
    "training_time_seconds": 320
  }
}

###
# 17. Buscar Experiências de Treinamento Neural
GET {{host}}{{api_v1_prefix}}/memory/recall?query=treinamento%20modelo%20neural
Accept: application/json

###
# 18. Verificar Sistema (Health Check via System Status)
GET {{host}}{{api_v1_prefix}}/system/status
Accept: application/json

###
# 19. Adicionar Experiência com PII (email/telefone) — deve ser mascarada
POST {{host}}{{api_v1_prefix}}/memory/memorize
Content-Type: application/json

{
  "type": "user_interaction",
  "content": "Usuário forneceu email john.doe@example.com e telefone +55 (11) 98765-4321",
  "metadata": {"origin": "http_tests"}
}

###
# 20. Recall Filtrado (status=failure)
GET {{host}}{{api_v1_prefix}}/memory/recall/filtered?query=erro&status=failure&limit=5&min_score=0.3
Accept: application/json

###
# 21. Falhas Recentes (janela padrão de cota)
GET {{host}}{{api_v1_prefix}}/memory/recall/recent_failures?limit=5&min_score=0.3
Accept: application/json


