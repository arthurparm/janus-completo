# @name s2_system_status
GET {{host}}{{api_v1_prefix}}/system/status
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

