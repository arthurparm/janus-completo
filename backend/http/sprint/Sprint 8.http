GET {{host}}{{api_v1_prefix}}/documents/list
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}
X-User-Id: {{actor_user_id}}

> {% client.test("documents/list: 200", function() { client.assert(response.status === 200); }); %}

