###
    # SPRINT 7: Conversacao e Feedback (Chat + Feedback)
    # Fluxos E2E reais + cobertura complementar de endpoints da sprint
    # Modulos: Chat, Feedback
    ###

    @host = http://localhost:8000
@api_v1_prefix = /api/v1
@token = 
@admin_token = 
@correlation_id = {{$timestamp}}
@client_version = 2.0.0
@actor_user_id = 1
@user_id_int = 1
@user_id_str = 1
@target_user_id = 1
@conversation_id = conv-placeholder
@message_id = msg-placeholder
@goal_id = goal-placeholder
@run_id = 1
@task_id = task-placeholder
@agent_id = agent-placeholder
@doc_id = doc-placeholder
@experiment_id = 1
@arm_id = 1
@model_id = demo-model
@request_id = req-demo
@action_id = 1
@consent_id = 1
@queue_name = janus.knowledge.consolidation
@queue_name_missing = default

@message_id = msg-placeholder


############################################
# 0) Preflight de autenticacao
############################################
# @name auth_local_me_preflight
GET {{host}}{{api_v1_prefix}}/auth/local/me
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Preflight auth/local/me: 200 e JSON", function() {
  client.assert(response.status === 200, "Forneca @token valido (auth/local/me != 200)");
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
try {
  const body = response.body.json();
  if (body && body.id) client.global.set("actor_user_id", String(body.id));
} catch (e) {}
%}
############################################
# Indice de endpoints cobertos nesta sprint
############################################
# - [Chat] GET /api/v1/chat/conversations
# - [Chat] GET /api/v1/chat/health
# - [Chat] POST /api/v1/chat/message
# - [Chat] POST /api/v1/chat/start
# - [Chat] GET /api/v1/chat/stream/{conversation_id}
# - [Chat] DELETE /api/v1/chat/{conversation_id}
# - [Chat] GET /api/v1/chat/{conversation_id}/events
# - [Chat] GET /api/v1/chat/{conversation_id}/history
# - [Chat] GET /api/v1/chat/{conversation_id}/history/paginated
# - [Chat] PUT /api/v1/chat/{conversation_id}/rename
# - [Chat] GET /api/v1/chat/{conversation_id}/trace
# - [Feedback] POST /api/v1/feedback/
# - [Feedback] GET /api/v1/feedback/conversation/{conversation_id}
# - [Feedback] GET /api/v1/feedback/report
# - [Feedback] GET /api/v1/feedback/stats
# - [Feedback] GET /api/v1/feedback/suggestions
# - [Feedback] POST /api/v1/feedback/thumbs-down
# - [Feedback] POST /api/v1/feedback/thumbs-up

############################################
# 1) Chat + Feedback (happy path)
############################################
# @name s7_chat_health
GET {{host}}{{api_v1_prefix}}/chat/health
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("chat/health: 200 ou 503", function() { client.assert([200,503].includes(response.status)); }); %}

