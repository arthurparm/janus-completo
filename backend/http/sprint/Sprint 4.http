# @name s4_tool_create_function
# DOCKER-SAFE: bloco desativado (mutacao/carga/external)
# POST {{host}}{{api_v1_prefix}}/tools/create/from-function
# Content-Type: application/json
# X-Request-ID: {{correlation_id}}
# User-Agent: Janus-HTTP-Test/{{client_version}}
# Authorization: Bearer {{token}}
#
# {
#   "name": "custom_demo_tool",
#   "description": "Soma dois inteiros",
#   "code": "def execute(a: int, b: int) -> int:\n    return a + b",
#   "function_name": "execute",
#   "category": "custom",
#   "permission_level": "safe",
#   "tags": ["demo"]
# }
#
# > {% client.test("create tool function: 201 ou 400", function() { client.assert([201,400].includes(response.status)); }); %}
#
###
