# @name s4_tools_list
GET {{host}}{{api_v1_prefix}}/tools/
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

