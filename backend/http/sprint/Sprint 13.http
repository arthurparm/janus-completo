###
# SPRINT 13: Meta-Agente - A Consciência Proativa
# Testes do supervisor autônomo com análise diagnóstica e heartbeat
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Health Check do Meta-Agente
GET {{host}}{{api_v1_prefix}}/meta-agent/health
Accept: application/json

###
# 2. Executar Análise Manual do Sistema
POST {{host}}{{api_v1_prefix}}/meta-agent/analyze
Content-Type: application/json

###
# 3. Obter Relatório Mais Recente
GET {{host}}{{api_v1_prefix}}/meta-agent/report/latest
Accept: application/json

###
# 4. Verificar Status do Heartbeat
GET {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/status
Accept: application/json

###
# 5. Iniciar Heartbeat (Intervalo 60 min)
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/start
Content-Type: application/json

{
  "interval_minutes": 60
}

###
# 6. Iniciar Heartbeat (Intervalo 30 min)
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/start
Content-Type: application/json

{
  "interval_minutes": 30
}

###
# 7. Parar Heartbeat
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/stop
Content-Type: application/json

###
# 8. Executar Nova Análise Após Mudanças no Sistema
POST {{host}}{{api_v1_prefix}}/meta-agent/analyze
Content-Type: application/json

###
# 9. Verificar Relatório Atualizado
GET {{host}}{{api_v1_prefix}}/meta-agent/report/latest
Accept: application/json
