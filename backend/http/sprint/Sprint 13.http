# @name s13_health_system
GET {{host}}{{api_v1_prefix}}/observability/health/system
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("observability/health/system: 200", function() { client.assert(response.status === 200); }); %}

