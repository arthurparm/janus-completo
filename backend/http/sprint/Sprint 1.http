###
# @name s1_users_add_consent
POST {{host}}{{api_v1_prefix}}/users/{{user_id_int}}/consents
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{s1_token}}
X-User-Id: {{s1_user_id}}

{
  "scope": "notes.read",
  "granted": true
}

> {% client.test("users/consents add: 200", function() { client.assert(response.status === 200); }); %}

###
# @name s1_users_list_consents
GET {{host}}{{api_v1_prefix}}/users/{{user_id_int}}/consents
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{s1_token}}
X-User-Id: {{s1_user_id}}

> {% client.test("users/consents list: 200", function() { client.assert(response.status === 200); }); %}

###
# @name s1_consents_grant_table
POST {{host}}{{api_v1_prefix}}/consents/
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{s1_token}}
X-User-Id: {{s1_user_id}}

{
  "user_id": "{{s1_user_id}}",
  "scope": "mail.read",
  "resource": "gmail",
  "notes": "Sprint 1 E2E"
}

> {%
client.test("consents/grant: 200", function() { client.assert(response.status === 200); });
const b = response.body.json();
client.global.set("consent_id", String(b.id));
%}

###
