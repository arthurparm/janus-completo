###
    # SPRINT 11: Colaboracao Multiagente e Workspace
    # Fluxos E2E reais + cobertura complementar de endpoints da sprint
    # Modulos: Collaboration, Collaboration - Workspace
    ###

    @host = http://localhost:8000
@api_v1_prefix = /api/v1
@token = 
@admin_token = 
@correlation_id = {{$timestamp}}
@client_version = 2.0.0
@actor_user_id = 1
@user_id_int = 1
@user_id_str = 1
@target_user_id = 1
@conversation_id = conv-placeholder
@message_id = msg-placeholder
@goal_id = goal-placeholder
@run_id = 1
@task_id = task-placeholder
@agent_id = agent-placeholder
@doc_id = doc-placeholder
@experiment_id = 1
@arm_id = 1
@model_id = demo-model
@request_id = req-demo
@action_id = 1
@consent_id = 1
@queue_name = janus.knowledge.consolidation
@queue_name_missing = default


############################################
# 0) Preflight de autenticacao
############################################
# @name auth_local_me_preflight
GET {{host}}{{api_v1_prefix}}/auth/local/me
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Preflight auth/local/me: 200 e JSON", function() {
  client.assert(response.status === 200, "Forneca @token valido (auth/local/me != 200)");
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
try {
  const body = response.body.json();
  if (body && body.id) client.global.set("actor_user_id", String(body.id));
} catch (e) {}
%}
############################################
# Indice de endpoints cobertos nesta sprint
############################################
# - [Collaboration] GET /api/v1/collaboration/agents
# - [Collaboration] POST /api/v1/collaboration/agents/create
# - [Collaboration] GET /api/v1/collaboration/agents/{agent_id}
# - [Collaboration] GET /api/v1/collaboration/health
# - [Collaboration] POST /api/v1/collaboration/projects/execute
# - [Collaboration] GET /api/v1/collaboration/tasks
# - [Collaboration] POST /api/v1/collaboration/tasks/create
# - [Collaboration] POST /api/v1/collaboration/tasks/execute
# - [Collaboration] POST /api/v1/collaboration/tasks/execute_parallel
# - [Collaboration] GET /api/v1/collaboration/tasks/{task_id}
# - [Collaboration] GET /api/v1/collaboration/workspace/status
# - [Collaboration - Workspace] POST /api/v1/collaboration/system/shutdown
# - [Collaboration - Workspace] POST /api/v1/collaboration/workspace/artifacts/add
# - [Collaboration - Workspace] GET /api/v1/collaboration/workspace/artifacts/{key}
# - [Collaboration - Workspace] POST /api/v1/collaboration/workspace/messages/send
# - [Collaboration - Workspace] GET /api/v1/collaboration/workspace/messages/{agent_id}

