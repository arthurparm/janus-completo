###
    # SPRINT 3: Execucao Assistida e Contexto (Context, Sandbox, Agent, Assistant)
    # Fluxos E2E reais + cobertura complementar de endpoints da sprint
    # Modulos: Context, Sandbox, Agent, Assistant, Auto Analysis
    ###

    @host = http://localhost:8000
@api_v1_prefix = /api/v1
@token = 
@admin_token = 
@correlation_id = {{$timestamp}}
@client_version = 2.0.0
@actor_user_id = 1
@user_id_int = 1
@user_id_str = 1
@target_user_id = 1
@conversation_id = conv-placeholder
@message_id = msg-placeholder
@goal_id = goal-placeholder
@run_id = 1
@task_id = task-placeholder
@agent_id = agent-placeholder
@doc_id = doc-placeholder
@experiment_id = 1
@arm_id = 1
@model_id = demo-model
@request_id = req-demo
@action_id = 1
@consent_id = 1
@queue_name = janus.knowledge.consolidation
@queue_name_missing = default


############################################
# 0) Preflight de autenticacao
############################################
# @name auth_local_me_preflight
GET {{host}}{{api_v1_prefix}}/auth/local/me
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Preflight auth/local/me: 200 e JSON", function() {
  client.assert(response.status === 200, "Forneca @token valido (auth/local/me != 200)");
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
try {
  const body = response.body.json();
  if (body && body.id) client.global.set("actor_user_id", String(body.id));
} catch (e) {}
%}
############################################
# Indice de endpoints cobertos nesta sprint
############################################
# - [Agent] POST /api/v1/agent/execute
# - [Assistant] POST /api/v1/assistant/execute
# - [Auto Analysis] GET /api/v1/auto-analysis/health-check
# - [Context] GET /api/v1/context/current
# - [Context] POST /api/v1/context/enriched
# - [Context] GET /api/v1/context/format-prompt
# - [Context] POST /api/v1/context/web-cache/invalidate
# - [Context] GET /api/v1/context/web-cache/status
# - [Context] GET /api/v1/context/web-search
# - [Sandbox] GET /api/v1/sandbox/capabilities
# - [Sandbox] POST /api/v1/sandbox/evaluate
# - [Sandbox] POST /api/v1/sandbox/execute

############################################
# 1) Contexto + Sandbox (happy path)
############################################
# @name s3_context_current
GET {{host}}{{api_v1_prefix}}/context/current
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("context/current: 200", function() { client.assert(response.status === 200); }); %}

###
# @name s3_web_search
GET {{host}}{{api_v1_prefix}}/context/web-search?query=janus%20api&max_results=3&search_depth=basic
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {% client.test("context/web-search: 200 ou 503", function() { client.assert([200,503].includes(response.status)); }); %}

###
