# @name s3_assistant_execute
# DOCKER-SAFE: bloco desativado (mutacao/carga/external)
# POST {{host}}{{api_v1_prefix}}/assistant/execute
# Content-Type: application/json
# X-Request-ID: {{correlation_id}}
# User-Agent: Janus-HTTP-Test/{{client_version}}
# Authorization: Bearer {{token}}
#
# {
#   "prompt": "Resumo curto do estado do Janus",
#   "risk_profile": "balanced",
#   "max_steps": 2,
#   "timeout_seconds": 10
# }
#
# > {% client.test("assistant/execute: 200 ou 500", function() { client.assert([200,500].includes(response.status)); }); %}
#
###
