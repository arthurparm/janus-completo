###
# @name s3_enriched_context
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

{
  "query": "janus observability",
  "include_web_search": true,
  "max_web_results": 2
}

> {% client.test("context/enriched: 200", function() { client.assert(response.status === 200); }); %}

