X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

{
  "code": "import os\nos.system('rm -rf /')",
  "context": {}
}

> {% client.test("sandbox invalid/block: 200 ou 400", function() { client.assert([200,400].includes(response.status)); }); %}

