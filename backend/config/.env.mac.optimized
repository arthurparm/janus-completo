# ===== Janus - Perfil otimizado para Mac mini M4 (10 CPU / 10 GPU, 24GB RAM) =====
# Arquivo: backend/config/.env.mac.optimized
# Uso sugerido:
#   cp backend/config/.env.mac.optimized backend/app/.env
#   cp backend/config/.env.mac.optimized .env

# ===== Ambiente =====
ENVIRONMENT=development
APP_NAME=Janus
APP_VERSION=0.1.0
AGENT_IDENTITY_NAME=Janus
IDENTITY_ENFORCEMENT_ENABLED=true

# ===== Compose / Host =====
DOCKER_SOCK=/var/run/docker.sock
INIT_MAS_AGENTS_ON_STARTUP=false

# ===== Credenciais base (dev/local) =====
MYSQL_ROOT_PASSWORD=janus_root
MYSQL_DATABASE=janus_config
MYSQL_USER=janus
MYSQL_PASSWORD=janus_pass

POSTGRES_USER=janus
POSTGRES_PASSWORD=janus_pass
POSTGRES_DB=janus_db

NEO4J_USER=neo4j
NEO4J_PASSWORD=password

RABBITMQ_USER=janus
RABBITMQ_PASSWORD=janus_pass

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Frontend env esperado pelo compose
VITE_SUPABASE_ANON_KEY=placeholder_anon_key_for_dev

# ===== DB/Infra tuning para Mac mini M4 24GB =====
NEO4J_HEAP_INITIAL=768M
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=512M

NEO4J_URI=bolt://neo4j:7687
QDRANT_HOST=qdrant
QDRANT_PORT=6333
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== LLM/Roteamento (moderado para Mac) =====
# Observacao: em compose o host deve ser "ollama"
OLLAMA_HOST=http://ollama:11434
OLLAMA_ORCHESTRATOR_MODEL=qwen2.5:14b
OLLAMA_CODER_MODEL=qwen2.5-coder:14b
OLLAMA_CURATOR_MODEL=qwen2.5:14b

LLM_EXECUTOR_MAX_WORKERS=6
LLM_POOL_MAX_SIZE=4
LLM_POOL_TTL_SECONDS=3600
LLM_POOL_WARM_PROVIDERS=[]

OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=3072
OLLAMA_NUM_BATCH=32
OLLAMA_NUM_THREAD=6
# Deixe vazio/omitido no Mac para auto-tune do Ollama:
# OLLAMA_GPU_LAYERS=

LLM_DEFAULT_TIMEOUT_SECONDS=180
LLM_RETRY_MAX_ATTEMPTS=4
LLM_RETRY_INITIAL_BACKOFF_SECONDS=0.8
LLM_RETRY_MAX_BACKOFF_SECONDS=8.0
LLM_RESPONSE_CACHE_USE_MSGPACK=true
OPENAI_HTTP_MAX_CONNECTIONS=80

# ===== Cache/memoria =====
MEMORY_SHORT_TTL_SECONDS=1200
MEMORY_SHORT_MAX_ITEMS=1024
MEMORY_SHORT_SCAN_MAX_ITEMS=512
MEMORY_MAX_CONTENT_CHARS=50000
CONTEXT_WEB_CACHE_TTL_SECONDS=3600
CONTEXT_WEB_CACHE_MAX_ITEMS=1536

# ===== Chat/SSE =====
CHAT_MAX_MESSAGE_BYTES=1048576
CHAT_DEFAULT_TIMEOUT_SECONDS=120
CHAT_HEARTBEAT_INTERVAL_SECONDS=10
CHAT_SSE_PROTOCOL_VERSION=2
CHAT_SSE_PARTIAL_DEPRECATE_AT=2026-12-31
CHAT_CB_COOLDOWN_SECONDS=60
CHAT_CB_FAILURE_THRESHOLD=7
CHAT_SSE_MAX_CONNECTIONS_PER_USER=3
CHAT_SSE_MAX_GLOBAL_CONNECTIONS=80

# ===== Timeout auto tune =====
TIMEOUT_AUTO_TUNE_ENABLED=true
TIMEOUT_AUTO_TUNE_PERCENTILE=0.95
TIMEOUT_AUTO_TUNE_PAD_SECONDS=0.8

# ===== Observabilidade =====
OTEL_ENABLED=false
OTEL_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=janus-backend-mac
LOG_SAMPLING_RATE=1.0
AUDIT_PURGE_INTERVAL_SECONDS=7200
AUDIT_RETENTION_DAYS=30

# ===== Frontend/Static =====
SERVE_STATIC_FILES=true
STATIC_FILES_DIR=frontend/dist/janus-angular/browser
VITE_API_BASE_URL=http://localhost:8000
VITE_FEATURE_SSE=true
VITE_UX_METRICS_SAMPLING=1.0
VITE_SSE_RETRY_MAX_SECONDS=45

# ===== Seguranca (preencher localmente) =====
AUTH_JWT_SECRET=__CHANGE_ME__
PUBLIC_API_KEY=
CORS_ALLOW_ORIGINS=["http://localhost:4300","http://127.0.0.1:4300","http://localhost:4200","http://127.0.0.1:4200"]

# ===== Chaves de provedor (nao commitar chaves reais) =====
OPENAI_API_KEY=
GEMINI_API_KEY=
