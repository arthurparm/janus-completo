{
  "title": "Janus Training — Overview",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "graph",
      "title": "Training Jobs (ok/error)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(neural_training_jobs_total{status=\"ok\"}[5m]))", "legendFormat": "ok" },
        { "expr": "sum(rate(neural_training_jobs_total{status=\"error\"}[5m]))", "legendFormat": "error" }
      ]
    },
    {
      "type": "graph",
      "title": "Training Latency p95",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(neural_training_job_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}