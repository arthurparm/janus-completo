###
# SPRINT 11: Colaboração Agêntica - Sociedade de Mentes
# Testes completos do sistema multi-agente com workspace compartilhado
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Health Check do Sistema Multi-Agente
GET {{host}}{{api_v1_prefix}}/collaboration/health
Accept: application/json

###
# 2. Criar Agente Gestor de Projetos
POST {{host}}{{api_v1_prefix}}/collaboration/agents/create
Content-Type: application/json

{
  "role": "project_manager"
}

###
# 3. Criar Agente Pesquisador
POST {{host}}{{api_v1_prefix}}/collaboration/agents/create
Content-Type: application/json

{
  "role": "researcher"
}

###
# 4. Criar Agente Desenvolvedor
POST {{host}}{{api_v1_prefix}}/collaboration/agents/create
Content-Type: application/json

{
  "role": "coder"
}

###
# 5. Criar Agente Testador
POST {{host}}{{api_v1_prefix}}/collaboration/agents/create
Content-Type: application/json

{
  "role": "tester"
}

###
# 6. Listar Todos os Agentes Ativos
GET {{host}}{{api_v1_prefix}}/collaboration/agents
Accept: application/json

###
# 7. Executar Projeto Completo (Coordenação Multi-Agente)
POST {{host}}{{api_v1_prefix}}/collaboration/projects/execute
Content-Type: application/json

{
  "description": "Criar uma função Python que calcula números de Fibonacci até N, incluindo testes unitários e documentação"
}

###
# 8. Criar Tarefa Manual
POST {{host}}{{api_v1_prefix}}/collaboration/tasks/create
Content-Type: application/json

{
  "description": "Implementar algoritmo de ordenação quicksort",
  "priority": "high"
}

###
# 9. Listar Todas as Tarefas
GET {{host}}{{api_v1_prefix}}/collaboration/tasks
Accept: application/json

###
# 10. Listar Tarefas Pendentes
GET {{host}}{{api_v1_prefix}}/collaboration/tasks?status=pending
Accept: application/json

###
# 11. Obter Status do Workspace Compartilhado
GET {{host}}{{api_v1_prefix}}/collaboration/workspace/status
Accept: application/json

###
# 12. Adicionar Artefato ao Workspace
# NOTA: Use o agent_id real retornado no teste #4 (coder)
# Exemplo: substitua CODER_AGENT_ID pelo ID retornado
POST {{host}}{{api_v1_prefix}}/collaboration/workspace/artifacts/add
Content-Type: application/json

{
  "key": "example_code.py",
  "value": "def hello_world():\n    print('Hello, World!')",
  "author": "CODER_AGENT_ID"
}

###
# 13. Recuperar Artefato do Workspace
GET {{host}}{{api_v1_prefix}}/collaboration/workspace/artifacts/example_code.py
Accept: application/json

###
# 14. Enviar Mensagem Entre Agentes
# NOTA: Use os agent_ids reais retornados nos testes #4 (coder) e #5 (tester)
POST {{host}}{{api_v1_prefix}}/collaboration/workspace/messages/send
Content-Type: application/json

{
  "from_agent": "CODER_AGENT_ID",
  "to_agent": "TESTER_AGENT_ID",
  "content": "Código implementado e pronto para testes"
}

###
# 15. Executar Projeto - Criação de API REST
POST {{host}}{{api_v1_prefix}}/collaboration/projects/execute
Content-Type: application/json

{
  "description": "Desenvolver uma API REST simples com endpoints para CRUD de usuários, incluindo validação, testes e documentação Swagger"
}
