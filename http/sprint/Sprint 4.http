# Variáveis para o ambiente de teste
@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# Teste de Agente 1: Fazer uma pergunta sobre o código ao Grafo de Conhecimento
# Pergunta: "O que a função trigger_indexing chama?"
# Resposta esperada: "index_codebase"
# ATUALIZADO: O endpoint foi corrigido para /agent/execute.
POST {{host}}{{api_v1_prefix}}/agent/execute
Content-Type: application/json

{
  "question": "Use a sua capacidade de consultar o grafo de conhecimento para descobrir quais funções a função 'trigger_indexing' chama diretamente."
}

> {%
    client.test("Agent query request successful", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Agent response contains the correct answer", function() {
        const data = response.body;
        const answer = data.answer.toLowerCase();
        client.assert(answer.includes("index_codebase"), "A resposta não contém 'index_codebase'");
    });
%}