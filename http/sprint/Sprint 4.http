###
# SPRINT 4: Sandbox Python Seguro e Ciclo ReAct
# Testes completos de execução segura de código Python
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Executar Código Python Simples
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "result = 2 + 2\nprint(f'A soma é: {result}')"
}

###
# 2. Executar Expressão Python
POST {{host}}{{api_v1_prefix}}/sandbox/execute-expression
Content-Type: application/json

{
  "expression": "sum([1, 2, 3, 4, 5])"
}

###
# 3. Executar Código com Imports Permitidos
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import math\nresult = math.sqrt(16)\nprint(f'Raiz quadrada de 16: {result}')"
}

###
# 4. Executar Código com JSON
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import json\ndata = {'name': 'Janus', 'version': '1.0'}\nprint(json.dumps(data, indent=2))"
}

###
# 5. Executar Código com Collections
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "from collections import Counter\nwords = ['apple', 'banana', 'apple', 'cherry', 'banana', 'apple']\ncount = Counter(words)\nprint(count)"
}

###
# 6. Executar Expressão Matemática Complexa
POST {{host}}{{api_v1_prefix}}/sandbox/execute-expression
Content-Type: application/json

{
  "expression": "[x**2 for x in range(10) if x % 2 == 0]"
}

###
# 7. Executar Código com Statistics
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import statistics\ndata = [1.5, 2.5, 3.5, 4.5, 5.5]\nmean = statistics.mean(data)\nmedian = statistics.median(data)\nprint(f'Média: {mean}, Mediana: {median}')"
}

###
# 8. Testar Código com Datetime
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "from datetime import datetime, timedelta\nnow = datetime.now()\ntomorrow = now + timedelta(days=1)\nprint(f'Hoje: {now.strftime(\"%Y-%m-%d\")}')\nprint(f'Amanhã: {tomorrow.strftime(\"%Y-%m-%d\")}')"
}

###
# 9. Health Check do Sandbox
GET {{host}}{{api_v1_prefix}}/sandbox/health
Accept: application/json

###
# 10. Executar Código que Deve Falhar (Import Não Permitido)
# Este teste deve retornar erro de forma controlada
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import os\nprint(os.listdir('/'))"
}
