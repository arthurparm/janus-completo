###
# SPRINT 3: Contexto Ambiental e Percepção Externa
# Testes completos de contexto, busca web e informações do sistema
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Obter Contexto Atual (Data/Hora + Sistema)
GET {{host}}{{api_v1_prefix}}/context/current
Accept: application/json

###
# 2. Buscar na Web - Tecnologia
GET {{host}}{{api_v1_prefix}}/context/web-search?query=Python%20asyncio%20tutorial&max_results=3&search_depth=basic
Accept: application/json

###
# 3. Buscar na Web - Notícias Atuais
GET {{host}}{{api_v1_prefix}}/context/web-search?query=artificial%20intelligence%20latest%20news&max_results=5&
    search_depth=basic
Accept: application/json

###
# 4. Contexto Enriquecido (sem busca web)
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "",
  "include_web_search": false
}

###
# 5. Contexto Enriquecido (com busca web)
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "machine learning frameworks",
  "include_web_search": true,
  "max_web_results": 3
}

###
# 6. Contexto Enriquecido - Uso Completo
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "best practices for microservices architecture",
  "include_web_search": true,
  "max_web_results": 5
}

###
# 7. Buscar na Web - Documentação
GET {{host}}{{api_v1_prefix}}/context/web-search?query=LangChain%20documentation%20agents&max_results=2&
    search_depth=basic
Accept: application/json

###
# 8. Buscar na Web - Busca Avançada
GET {{host}}{{api_v1_prefix}}/context/web-search?query=microservices%20design%20patterns&max_results=5&
    search_depth=advanced
Accept: application/json

###
# 9. Formatar Contexto para Prompt - Somente Data/Hora
GET {{host}}{{api_v1_prefix}}/context/format-prompt?include_datetime=true&include_system=false
Accept: application/json

###
# 10. Formatar Contexto para Prompt - Completo com Busca Web
GET {{host}}{{api_v1_prefix}}/context/format-prompt?include_datetime=true&include_system=true&
    web_query=circuit%20breakers%20Python
Accept: application/json

###
# 11. Obter Contexto Atual para Tomada de Decisão
GET {{host}}{{api_v1_prefix}}/context/current
Accept: application/json

###
# 12. Contexto Enriquecido - Caso Complexo
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "distributed systems consensus algorithms",
  "include_web_search": true,
  "max_web_results": 4
}