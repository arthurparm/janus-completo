###
# SPRINT 5: Sistema Reflexion - Auto-otimização e Aprendizado com Erros
# Testes completos do ciclo ACT-EVALUATE-REFLECT-RETRY-LEARN
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Resetar o circuit breaker
POST http://localhost:8000/api/v1/reflexion/reset-circuit-breaker

###
# 2. Verificar health (deve mostrar CLOSED)
GET http://localhost:8000/api/v1/reflexion/health
Accept: application/json


###
# 1. Executar Tarefa Simples com Reflexion
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Calcular a soma de [10, 20, 30, 40, 50]",
  "max_iterations": 3,
  "max_time_seconds": 60
}

###
# 2. Executar Tarefa com Múltiplas Iterações
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Listar todos os números primos entre 1 e 100",
  "max_iterations": 5,
  "max_time_seconds": 90
}

###
# 3. Executar Tarefa Simples de Cálculo
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Calcular a média de [15, 25, 35, 45, 55] e explicar o método",
  "max_iterations": 3,
  "max_time_seconds": 60
}

###
# 4. Executar Tarefa com Threshold Customizado
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Gerar os primeiros 10 números da sequência de Fibonacci",
  "max_iterations": 4,
  "max_time_seconds": 80,
  "success_threshold": 0.9
}

###
# 5. Executar Tarefa com Threshold Baixo
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Criar uma lista com os quadrados dos números de 1 a 10",
  "max_iterations": 2,
  "max_time_seconds": 40,
  "success_threshold": 0.6
}

###
# 6. Obter Configuração do Reflexion
GET {{host}}{{api_v1_prefix}}/reflexion/config
Accept: application/json

###
# 7. Executar Tarefa com Configuração Mínima
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Calcular o fatorial de 5",
  "max_iterations": 2,
  "max_time_seconds": 30
}

###
# 8. Executar Tarefa de Processamento de String
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Inverter a string 'Hello World' e converter para maiúsculas",
  "max_iterations": 3,
  "max_time_seconds": 60
}

###
# 9. Health Check do Sistema Reflexion
GET {{host}}{{api_v1_prefix}}/reflexion/health
Accept: application/json

###
# 10. Executar Tarefa com Todas as Configurações
POST {{host}}{{api_v1_prefix}}/reflexion/execute
Content-Type: application/json

{
  "task": "Criar um dicionário com as vogais do alfabeto como chaves e suas posições como valores",
  "max_iterations": 5,
  "max_time_seconds": 120,
  "success_threshold": 0.85
}


