# Sprint 3: Contexto Ambiental e Percepção
# Testes para as funcionalidades de contexto e busca web

# Variáveis para o ambiente de teste
@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# Teste 1: Obter contexto atual (data/hora e sistema)
GET {{host}}{{api_v1_prefix}}/context/current
Accept: application/json

> {%
    client.test("Context current request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains timestamp", function () {
        const context = response.body;
        client.assert(context.timestamp !== undefined, "Timestamp not found");
        client.assert(context.datetime_info !== undefined, "datetime_info not found");
        client.assert(context.system_info !== undefined, "system_info not found");
    });
    client.test("Datetime info contains expected fields", function () {
        const dt = response.body.datetime_info;
        client.assert(dt.utc !== undefined, "UTC time not found");
        client.assert(dt.date !== undefined, "Date not found");
        client.assert(dt.day_of_week !== undefined, "Day of week not found");
    });
%}

###
# Teste 2: Buscar na web (Tavily)
GET {{host}}{{api_v1_prefix}}/context/web-search?query=Python best practices&max_results=3&search_depth=basic
Accept: application/json

> {%
    client.test("Web search request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains search results", function () {
        const result = response.body;
        client.assert(result.query === "Python best practices", "Query mismatch");
        client.assert(result.results !== undefined, "Results not found");
        client.assert(Array.isArray(result.results), "Results is not an array");
    });
    client.test("Search results have expected structure", function () {
        const results = response.body.results;
        if (results.length > 0) {
            const first = results[0];
            client.assert(first.title !== undefined, "Title not found in result");
            client.assert(first.url !== undefined, "URL not found in result");
            client.assert(first.content !== undefined, "Content not found in result");
        }
    });
%}

###
# Teste 3: Contexto enriquecido sem busca web
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "",
  "include_web_search": false,
  "max_web_results": 3
}

> {%
    client.test("Enriched context (no web) request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains environmental context", function () {
        const context = response.body;
        client.assert(context.environmental !== undefined, "Environmental context not found");
        client.assert(context.web_search === null, "Web search should be null");
    });
%}

###
# Teste 4: Contexto enriquecido COM busca web
POST {{host}}{{api_v1_prefix}}/context/enriched
Content-Type: application/json

{
  "query": "FastAPI tutorial",
  "include_web_search": true,
  "max_web_results": 3
}

> {%
    client.test("Enriched context (with web) request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains both environmental and web search", function () {
        const context = response.body;
        client.assert(context.environmental !== undefined, "Environmental context not found");
        client.assert(context.web_search !== undefined, "Web search not found");
        client.assert(context.web_search !== null, "Web search should not be null");
    });
    client.test("Web search results present", function () {
        const webSearch = response.body.web_search;
        client.assert(webSearch.query === "FastAPI tutorial", "Query mismatch");
        client.assert(Array.isArray(webSearch.results), "Results is not an array");
    });
%}

###
# Teste 5: Formatar contexto para prompt (somente datetime)
GET {{host}}{{api_v1_prefix}}/context/format-prompt?include_datetime=true&include_system=false
Accept: application/json

> {%
    client.test("Format prompt request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains formatted context", function () {
        const result = response.body;
        client.assert(result.formatted_context !== undefined, "Formatted context not found");
        client.assert(typeof result.formatted_context === "string", "Formatted context is not a string");
    });
    client.test("Formatted context contains datetime info", function () {
        const formatted = response.body.formatted_context;
        client.assert(formatted.includes("Data/Hora"), "DateTime info not found in formatted context");
    });
%}

###
# Teste 6: Formatar contexto para prompt (com sistema)
GET {{host}}{{api_v1_prefix}}/context/format-prompt?include_datetime=true&include_system=true
Accept: application/json

> {%
    client.test("Format prompt with system request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Formatted context contains system info", function () {
        const formatted = response.body.formatted_context;
        client.assert(formatted.includes("Sistema"), "System info not found in formatted context");
    });
%}

###
# Teste 7: Formatar contexto para prompt COM busca web
GET {{host}}{{api_v1_prefix}}/context/format-prompt?include_datetime=true&include_system=false&
    web_query=Langchain documentation
Accept: application/json

> {%
    client.test("Format prompt with web search successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Formatted context contains web results", function () {
        const formatted = response.body.formatted_context;
        client.assert(formatted.includes("Resultados da Busca Web"), "Web search results not found in formatted context");
    });
%}

###
# Teste 8: Testar busca web com profundidade avançada
GET {{host}}{{api_v1_prefix}}/context/web-search?query=AI developments 2025&max_results=5&search_depth=advanced
Accept: application/json

> {%
    client.test("Advanced web search request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response contains results", function () {
        const result = response.body;
        client.assert(result.results !== undefined, "Results not found");
        client.assert(result.results.length <= 5, "Too many results returned");
    });
%}

###
# Teste 9: Validar limite máximo de resultados
GET {{host}}{{api_v1_prefix}}/context/web-search?query=test&max_results=10&search_depth=basic
Accept: application/json

> {%
    client.test("Max results limit respected", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const result = response.body;
        client.assert(result.results.length <= 10, "Results exceed max_results parameter");
    });
%}

###
# Teste 10: Validar erro com search_depth inválido (deve retornar erro de validação)
GET {{host}}{{api_v1_prefix}}/context/web-search?query=test&max_results=5&search_depth=invalid
Accept: application/json

> {%
    client.test("Invalid search_depth returns validation error", function () {
        client.assert(response.status === 422, "Expected validation error (422)");
    });
%}
