###
# 8. Estatísticas do Grafo de Conhecimento
# @name knowledge_stats
GET {{host}}{{api_v1_prefix}}/knowledge/stats
Accept: application/json

> {%
client.test("Stats: status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const statsJson = response.body.json();
client.test("Stats: campos principais", function() {
  client.assert(typeof statsJson.total_nodes === "number");
  client.assert(typeof statsJson.total_relationships === "number");
  client.assert(Array.isArray(statsJson.node_types));
  client.assert(Array.isArray(statsJson.relationship_types));
});
%}

###
# 9. Listar Tipos de Nós no Grafo
# @name node_types
GET {{host}}{{api_v1_prefix}}/knowledge/node-types
Accept: application/json

> {%
client.test("Node Types: status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const typesJson = response.body.json();
client.test("Node Types: lista de strings", function() {
  client.assert(Array.isArray(typesJson.types));
  if (typesJson.types.length > 0) {
    client.assert(typeof typesJson.types[0] === "string");
  }
});
%}

###
# 10. Health Check da Memória Semântica
# @name knowledge_health
GET {{host}}{{api_v1_prefix}}/knowledge/health
Accept: application/json

> {%
client.test("Health: status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const healthJson = response.body.json();
client.test("Health: campos esperados", function() {
  client.assert(typeof healthJson.status === "string");
  client.assert(typeof healthJson.neo4j_connected === "boolean");
  client.assert(typeof healthJson.total_nodes === "number");
  client.assert(typeof healthJson.total_relationships === "number");
});
%}

###
# 9. Listar Funções que chamam uma função
GET http://localhost:8000/api/v1/knowledge/functions/calling?name=run_agent_async

### Knowledge: arquivos que importam um módulo/arquivo
GET http://localhost:8000/api/v1/knowledge/files/importing?module=resilience.py

### Knowledge: classes que implementam um protocolo/interface
GET http://localhost:8000/api/v1/knowledge/classes/implementations?protocol=AgentExecutor
