###
# SPRINT 8: Memória Semântica - Consolidação de Conhecimento em Grafo
# Testes completos de consulta e consolidação do grafo de conhecimento (Neo4j)
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Consolidar Conhecimento da Memória Episódica
POST {{host}}{{api_v1_prefix}}/knowledge/consolidate
Content-Type: application/json

{
  "limit": 100,
  "batch_size": 10
}

###
# 2. Consultar Grafo de Conhecimento - Conceitos Relacionados a Python
POST {{host}}{{api_v1_prefix}}/knowledge/query
Content-Type: application/json

{
  "query": "Quais conceitos estão relacionados a Python?",
  "limit": 10
}

###
# 3. Consultar Grafo de Conhecimento - Erros e Falhas
POST {{host}}{{api_v1_prefix}}/knowledge/query
Content-Type: application/json

{
  "query": "Quais erros foram registrados no sistema?",
  "limit": 15
}

###
# 4. Buscar Conceitos Relacionados
POST {{host}}{{api_v1_prefix}}/knowledge/concepts/related
Content-Type: application/json

{
  "concept": "LangChain",
  "max_depth": 2
}

###
# 5. Buscar Conceitos Relacionados - Profundidade Maior
POST {{host}}{{api_v1_prefix}}/knowledge/concepts/related
Content-Type: application/json

{
  "concept": "agent",
  "max_depth": 3
}

###
# 6. Obter Detalhes de Entidade - Ferramenta
POST {{host}}{{api_v1_prefix}}/knowledge/entity/details
Content-Type: application/json

{
  "entity_name": "write_file"
}

###
# 7. Obter Detalhes de Entidade - Conceito
POST {{host}}{{api_v1_prefix}}/knowledge/entity/details
Content-Type: application/json

{
  "entity_name": "reflexion"
}

###
# 8. Estatísticas do Grafo de Conhecimento
GET {{host}}{{api_v1_prefix}}/knowledge/stats
Accept: application/json

###
# 9. Listar Tipos de Nós no Grafo
GET {{host}}{{api_v1_prefix}}/knowledge/node-types
Accept: application/json

###
# 10. Health Check da Memória Semântica
GET {{host}}{{api_v1_prefix}}/knowledge/health
Accept: application/json
