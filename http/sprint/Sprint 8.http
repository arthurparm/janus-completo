###
# SPRINT 8: Memória Semântica - Consolidação de Conhecimento em Grafo
# Testes completos de consulta e consolidação do grafo de conhecimento (Neo4j)
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1
@concept_langchain = LangChain
@concept_agent = agent
@entity_tool = write_file
@entity_concept = reflexion
@max_depth = 2
@max_depth_deep = 3
@rel_limit = 20
@rel_skip = 0
@query_limit_small = 10
@query_limit_medium = 15
@consolidate_limit = 5
@consolidate_batch_size = 5

###
# 0. LIMPAR Grafo de Conhecimento (Use com cuidado!)
# @name clear_graph
DELETE {{host}}{{api_v1_prefix}}/knowledge/clear
Accept: application/json

> {%
client.test("Clear: status 200 e JSON", function() {
  client.assert(response.status === 200, "Status não é 200");
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"), "Content-Type não é JSON");
});
const clearJson = response.body.json();
client.test("Clear: corpo esperado", function() {
  client.assert(clearJson.status === "success", "status != success");
  client.assert(clearJson.message === "Grafo de conhecimento limpo com sucesso", "Mensagem inesperada");
  client.assert(typeof clearJson.remaining_nodes === "number" && clearJson.remaining_nodes >= 0, "remaining_nodes inválido");
});
%}

###
# 1. Consolidar Conhecimento da Memória Episódica
# ATENÇÃO: Cada experiência leva ~5-20s para processar (chamada LLM)
# Com limit=5, espere ~25-100s (até 2 minutos)
# @name consolidate_batch
POST {{host}}{{api_v1_prefix}}/knowledge/consolidate
Content-Type: application/json

{
  "limit": {{consolidate_limit}},
  "batch_size": {{consolidate_batch_size}}
}

> {%
client.test("Consolidate: status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const consJson = response.body.json();
client.test("Consolidate: mensagem e stats", function() {
  client.assert(consJson.message === "Tarefa de consolidação publicada.");
  client.assert(typeof consJson.stats === "object" && consJson.stats !== null, "stats deve ser objeto");
});
%}

###
# 2. Consultar Grafo de Conhecimento - Conceitos Relacionados a Python
# @name query_python
POST {{host}}{{api_v1_prefix}}/knowledge/query
Content-Type: application/json

{
  "query": "Quais conceitos estão relacionados a Python?",
  "limit": {{query_limit_small}}
}

> {%
client.test("Query(Python): status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const qPython = response.body.json();
client.test("Query(Python): answer string", function() {
  client.assert(typeof qPython.answer === "string", "answer deve ser string");
});
%}

###
# 3. Consultar Grafo de Conhecimento - Erros e Falhas
# @name query_errors
POST {{host}}{{api_v1_prefix}}/knowledge/query
Content-Type: application/json

{
  "query": "Quais erros foram registrados no sistema?",
  "limit": {{query_limit_medium}}
}

> {%
client.test("Query(Erros): status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const qErrors = response.body.json();
client.test("Query(Erros): answer string", function() {
  client.assert(typeof qErrors.answer === "string");
});
%}

###
# 4. Buscar Conceitos Relacionados
# @name concepts_related_langchain
POST {{host}}{{api_v1_prefix}}/knowledge/concepts/related
Content-Type: application/json

{
  "concept": "{{concept_langchain}}",
  "max_depth": {{max_depth}}
}

> {%
client.test("Related(LangChain): status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const relLang = response.body.json();
client.test("Related(LangChain): estrutura results", function() {
  client.assert(Array.isArray(relLang.results), "results deve ser array");
  if (relLang.results.length > 0) {
    const it = relLang.results[0];
    client.assert(typeof it.concept === "string");
    client.assert(typeof it.relationship === "string");
    client.assert(typeof it.distance === "number");
  }
});
%}

###
# 5. Buscar Conceitos Relacionados - Profundidade Maior
# @name concepts_related_agent
POST {{host}}{{api_v1_prefix}}/knowledge/concepts/related
Content-Type: application/json

{
  "concept": "{{concept_agent}}",
  "max_depth": {{max_depth_deep}}
}

> {%
client.test("Related(agent): status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const relAgent = response.body.json();
client.test("Related(agent): estrutura results", function() {
  client.assert(Array.isArray(relAgent.results), "results deve ser array");
  if (relAgent.results.length > 0) {
    const it = relAgent.results[0];
    client.assert(typeof it.concept === "string");
    client.assert(typeof it.relationship === "string");
    client.assert(typeof it.distance === "number");
  }
});
%}

###
# 6. Obter Relacionamentos de Entidade - Ferramenta
# @name entity_relationships_write_file
GET {{host}}{{api_v1_prefix}}/knowledge/entity/{{entity_tool}}/relationships?max_depth={{max_depth}}&limit={{rel_limit}}&skip={{rel_skip}}
Accept: application/json

> {%
client.test("Entity(write_file): status 200 e JSON", function() {
  client.assert(response.status === 200);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("application/json"));
});
const relWriteFile = response.body.json();
client.test("Entity(write_file): estrutura results", function() {
  client.assert(Array.isArray(relWriteFile.results), "results deve ser array");
  if (relWriteFile.results.length > 0) {
    const it = relWriteFile.results[0];
    client.assert(typeof it.related_entity === "string");
    client.assert(typeof it.related_type === "string");
    client.assert(typeof it.relationship === "string");
    client.assert(typeof it.distance === "number");
  }
});
%}

###
# 7. Obter Relacionamentos de Entidade - Conceito
# @name entity_relationships_reflexion
GET {{host}}{{api_v1_prefix}}/knowledge/entity/{{entity_concept}}/relationships?max_depth={{max_depth}}&limit={{rel_limit}}&skip={{rel_skip}}
Accept: application/json

