###
# Teste 7: Executar código com regex
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import re\ntext = 'Email: test@example.com'\npattern = r'[\\w\\.-]+@[\\w\\.-]+'\nemail = re.search(pattern, text)\nif email:\n    print(f'Found: {email.group()}')"
}

> {%
    client.test("Regex processing successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("test@example.com"), "Regex match incorrect");
    });
%}

###
# Teste 8: Executar função definida pelo usuário
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "def fibonacci(n):\n    if n <= 1:\n        return n\n    return fibonacci(n-1) + fibonacci(n-2)\n\nresult = [fibonacci(i) for i in range(8)]\nprint(f'Fibonacci: {result}')"
}

> {%
    client.test("User-defined function works", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("[0, 1, 1, 2, 3, 5, 8, 13]"), "Fibonacci sequence incorrect");
    });
%}

