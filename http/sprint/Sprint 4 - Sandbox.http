###############################################################################
# PARTE 3: TESTES DE SEGURANÇA - CASOS QUE DEVEM FALHAR
###############################################################################

###
# Teste 13: Bloquear import de 'os'
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import os\nprint(os.listdir('.'))"
}

> {%
    client.test("OS import blocked", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === false, "Should have failed");
        client.assert(data.error !== null, "Should have error message");
    });
%}

