###############################################################################
# PARTE 5: VERIFICAR CAPACIDADES DO SANDBOX
###############################################################################

###
# Teste 22: Listar capacidades do sandbox
GET {{host}}{{api_v1_prefix}}/sandbox/capabilities
Accept: application/json

> {%
    client.test("Capabilities request successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Capabilities structure correct", function () {
        const data = response.body;
        client.assert(data.allowed_modules !== undefined, "allowed_modules missing");
        client.assert(data.restrictions !== undefined, "restrictions missing");
        client.assert(data.features !== undefined, "features missing");
    });
    client.test("Security restrictions present", function () {
        const restrictions = response.body.restrictions;
        client.assert(restrictions.filesystem_access === false, "Filesystem should be blocked");
        client.assert(restrictions.network_access === false, "Network should be blocked");
        client.assert(restrictions.subprocess === false, "Subprocess should be blocked");
    });
%}

