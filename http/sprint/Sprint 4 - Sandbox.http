###
# Teste 23: Executar código com contexto personalizado
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "result = base_value * multiplier\nprint(f'Resultado: {result}')",
  "context": {
    "base_value": 10,
    "multiplier": 5
  }
}

> {%
    client.test("Code with context successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("Resultado: 50"), "Context variables not working");
    });
%}

