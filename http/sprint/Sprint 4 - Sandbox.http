# Sprint 4: Sandbox Python Seguro e Ciclo ReAct
# Testes para execução segura de código Python

# Variáveis para o ambiente de teste
@host = http://localhost:8000
@api_v1_prefix = /api/v1

###############################################################################
# PARTE 1: TESTES DO SANDBOX - CASOS DE SUCESSO
###############################################################################

###
# Teste 1: Executar código Python simples
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "result = 2 + 2\nprint(f'Resultado: {result}')"
}

> {%
    client.test("Execute simple code successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Code executed successfully", function () {
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("Resultado: 4"), "Output incorrect");
    });
%}

###
# Teste 2: Executar código com import math
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "import math\narea = math.pi * 5 ** 2\nprint(f'Área do círculo: {area:.2f}')"
}

> {%
    client.test("Math import allowed", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("Área do círculo"), "Output incorrect");
    });
%}

###
# Teste 3: Executar código com listas e loops
POST {{host}}{{api_v1_prefix}}/sandbox/execute
Content-Type: application/json

{
  "code": "numbers = [1, 2, 3, 4, 5]\ntotal = sum(numbers)\naverage = total / len(numbers)\nprint(f'Média: {average}')"
}

> {%
    client.test("List processing successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
        const data = response.body;
        client.assert(data.success === true, "Execution failed");
        client.assert(data.output.includes("Média: 3"), "Average calculation incorrect");
        client.assert(data.variables.total === "15", "Total variable incorrect");
    });
%}

