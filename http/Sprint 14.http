# Variáveis para o ambiente de teste do Sprint 14
@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# Teste 1: Induzir uma Falha Controlada
# Objetivo: Criar uma memória de uma ação que falhou para que o Meta-Agente
# possa encontrá-la. Pedimos para usar 'write_file' sem o argumento 'content'.
POST {{host}}{{api_v1_prefix}}/agent/execute
Content-Type: application/json

{
  "question": "Use a ferramenta write_file, mas forneça apenas o file_path como 'teste_falha.txt'.",
  "agent_type": "tool_user"
}

> {%
    client.test("Induce failure request completed", function() {
        // Esperamos um erro 500 porque a tarefa falhará após todas as tentativas.
        client.assert(response.status === 500, "Response status is not 500");
        client.log("Failure successfully induced and recorded in memory.");
    });
%}

###
# Teste 2: Acionar o Ciclo do Meta-Agente
# Objetivo: Forçar o Meta-Agente a "acordar" e analisar a memória imediatamente.
POST {{host}}{{api_v1_prefix}}/system/trigger_meta_agent
Content-Type: application/json

> {%
    client.test("Meta-Agent cycle triggered successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.log("Meta-Agent trigger endpoint returned success. Verifique os logs do servidor para a validação.");
    });
%}
