# Variáveis para o ambiente de teste
@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# Teste 2: Disparar a indexação da base de código
# Deve retornar 200 OK e uma mensagem de sucesso.
POST {{host}}{{api_v1_prefix}}/knowledge/index
Content-Type: application/json

> {%
    client.test("Indexing request successful", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response body indicates success", function() {
        const data = response.body;
        client.assert(data.message === "Indexação da base de código concluída.", "Success message not found");
        client.assert(data.files_indexed > 0, "Number of indexed files should be greater than 0");
    });
%}

###
# Teste 3: Listar os arquivos indexados
# Deve retornar 200 OK e uma lista de arquivos que inclui o 'app/main.py'.
GET {{host}}{{api_v1_prefix}}/knowledge/files
Accept: application/json

> {%
    client.test("List files request successful", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.test("Response body is a list of files", function() {
        const data = response.body;
        client.assert(Array.isArray(data.files), "Response 'files' is not an array");
        client.assert(data.files.length > 0, "File list is empty");
    });
    client.test("Key files are present in the list", function() {
        const data = response.body;
        const mainPyExists = data.files.some(file => file.includes("app/main.py"));
        const thisTestFileExists = data.files.some(file => file.includes("app/api/v1/endpoints/knowledge.py"));
        client.assert(mainPyExists, "'app/main.py' not found in the indexed files");
        client.assert(thisTestFileExists, "'knowledge.py' not found in the indexed files");
    });
%}