    {
      "id": "TP-WEB-TAVILY",
      "category": "web_search",
      "provider_keys": ["tavily"],
      "hosts": ["api.tavily.com"],
      "enablement": ["TAVILY_API_KEY"],
      "data_categories": ["queries", "urls", "snippets"],
      "transfer": "international",
      "code_refs": ["backend/app/core/infrastructure/context_manager.py"]
    },
    {
      "id": "TP-AUTH-FIREBASE",
      "category": "auth",
      "provider_keys": ["firebase"],
      "hosts": ["identitytoolkit.googleapis.com", "securetoken.googleapis.com"],
      "enablement": ["FIREBASE_ENABLED", "FIREBASE_CREDENTIALS_PATH"],
      "data_categories": ["auth_tokens", "user_profile"],
      "transfer": "international",
      "code_refs": ["backend/app/api/v1/endpoints/auth.py", "backend/app/config.py"]
    },
    {
      "id": "TP-AUTH-SUPABASE",
      "category": "auth",
      "provider_keys": ["supabase"],
      "hosts": [],
      "enablement": ["SUPABASE_JWT_SECRET"],
