      "enablement": ["DEEPSEEK_API_KEY"],
      "data_categories": ["chat_prompts", "documents", "metadata"],
      "transfer": "international",
      "code_refs": ["backend/app/core/llm/router.py", "backend/app/core/llm/factory.py"]
    },
    {
      "id": "TP-LLM-XAI",
      "category": "llm",
