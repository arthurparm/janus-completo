      "enablement": ["OPENROUTER_API_KEY"],
      "data_categories": ["chat_prompts", "documents", "metadata"],
      "transfer": "international",
      "code_refs": ["backend/app/core/llm/factory.py", "backend/app/config.py"]
    },
    {
      "id": "TP-OAUTH-GOOGLE",
      "category": "oauth",
      "provider_keys": ["google"],
      "hosts": ["oauth2.googleapis.com", "www.googleapis.com", "gmail.googleapis.com"],
      "enablement": ["GOOGLE_OAUTH_CLIENT_ID", "GOOGLE_OAUTH_CLIENT_SECRET"],
      "data_categories": ["oauth_tokens", "emails", "calendar_events"],
      "transfer": "international",
