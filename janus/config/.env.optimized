# ===== CONFIGURAÇÃO OTIMIZADA PARA: i9 13900F + 64GB DDR5 + RTX 4060 Ti 16GB =====
# Arquivo: janus/config/.env.optimized
# Copie para janus/config/.env para usar

# ===== Ambiente e Identidade =====
ENVIRONMENT=production
APP_NAME=Janus
APP_VERSION=0.1.0
AGENT_IDENTITY_NAME=Janus
IDENTITY_ENFORCEMENT_ENABLED=true

# ===== OTIMIZAÇÃO PARA i9 13900F (24 cores/32 threads) =====
# Paralelização máxima para CPU de alto desempenho
LLM_EXECUTOR_MAX_WORKERS=16              # Usar mais cores para processamento paralelo
OLLAMA_NUM_THREAD=32                     # Usar todas as threads disponíveis
LLM_POOL_MAX_SIZE=12                     # Maior pool para reuso de conexões
LLM_POOL_TTL_SECONDS=7200               # Manter conexões por mais tempo (2h)

# Otimização de threads para bibliotecas científicas
OMP_NUM_THREADS=32                      # OpenMP: usar todas as threads
MKL_NUM_THREADS=32                      # Intel MKL: otimizado para i9
NUMEXPR_NUM_THREADS=32                  # NumExpr: máxima paralelização

# ===== OTIMIZAÇÃO PARA RTX 4060 Ti 16GB VRAM =====
# Configurações específicas para GPU de 16GB
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=120m                  # Manter modelos por 2h (menos cold-start)
OLLAMA_NUM_CTX=8192                     # Dobro do contexto para melhor performance
OLLAMA_NUM_BATCH=128                    # Batch maior para throughput
OLLAMA_GPU_LAYERS=48                    # Usar mais camadas na GPU (16GB VRAM)

# CUDA - Otimizações para RTX 4060 Ti
CUDA_DEVICE_MAX_CONNECTIONS=128         # Mais conexões para melhor concorrência
CUDA_CACHE_MAXSIZE=2147483648           # 2GB de cache (dobro do padrão)
CUDA_LAUNCH_BLOCKING=0                  # Não bloquear launches (assíncrono)
CUDA_VISIBLE_DEVICES=0                  # Usar GPU 0

# ===== OTIMIZAÇÃO PARA 64GB DDR5 =====
# Aproveitar memória abundante para caching
MEMORY_SHORT_TTL_SECONDS=1800           # 30 min de cache curto
MEMORY_SHORT_MAX_ITEMS=3072             # 3x mais itens em cache
MEMORY_SHORT_SCAN_MAX_ITEMS=1024        # Scan maior
MEMORY_MAX_CONTENT_CHARS=80000          # Dobro do limite de conteúdo

# Cache web para RAG (aproveitar RAM)
CONTEXT_WEB_CACHE_TTL_SECONDS=7200      # 2h de cache
CONTEXT_WEB_CACHE_MAX_ITEMS=6144        # 6x mais itens cacheados
LLM_RESPONSE_CACHE_USE_MSGPACK=true     # MsgPack para menor overhead

# ===== TIMEOUTS OTIMIZADOS PARA PERFORMANCE =====
# Timeouts maiores para modelos locais grandes
LLM_DEFAULT_TIMEOUT_SECONDS=120         # 2 min para modelos grandes
LLM_RETRY_MAX_ATTEMPTS=5                # Mais tentativas
LLM_RETRY_INITIAL_BACKOFF_SECONDS=1.0   # Backoff inicial maior
LLM_RETRY_MAX_BACKOFF_SECONDS=10.0    # Backoff máximo maior

# Auto-tune de timeouts habilitado
TIMEOUT_AUTO_TUNE_ENABLED=true
TIMEOUT_AUTO_TUNE_PERCENTILE=0.98       # 98º percentil
TIMEOUT_AUTO_TUNE_PAD_SECONDS=2.0      # 2s de margem

# ===== SSE/CHAT - BAIXA LATÊNCIA =====
CHAT_MAX_MESSAGE_BYTES=2097152          # 2MB para mensagens grandes
CHAT_DEFAULT_TIMEOUT_SECONDS=180        # 3 min para streaming
CHAT_HEARTBEAT_INTERVAL_SECONDS=5       # Heartbeat mais frequente
CHAT_SSE_PROTOCOL_VERSION=2
CHAT_SSE_PARTIAL_DEPRECATE_AT=180       # 3 min de validade

# Circuit breaker mais permissivo
CHAT_CB_COOLDOWN_SECONDS=60             # 1 min de cooldown
CHAT_CB_FAILURE_THRESHOLD=10            # Mais falhas permitidas

# ===== MODELOS LOCAIS OTIMIZADOS PARA 16GB VRAM =====
# Modelos que cabem em 16GB VRAM com boa performance
OLLAMA_ORCHESTRATOR_MODEL=llama3.1:8b-instruct-q5_K_M    # 8B q5 - balanceado
OLLAMA_CODER_MODEL=codellama:7b-instruct-q5_K_M           # 7B q5 - código
OLLAMA_CURATOR_MODEL=phi3:14b-instruct-q4_K_M             # 14B q4 - maior mas cabe

# ===== HTTP/GPU POOLING =====
OPENAI_HTTP_MAX_CONNECTIONS=400           # 2x mais conexões
OPENAI_HTTP_MAX_KEEPALIVE=100           # 2x mais keepalive
OPENAI_HTTP_TIMEOUT_SECONDS=120          # Timeout dobrado

# ===== OBSERVABILIDADE =====
OTEL_ENABLED=true
OTEL_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=janus-backend-optimized
LOG_SAMPLING_RATE=1.0                    # Log completo para debug
AUDIT_PURGE_INTERVAL_SECONDS=7200         # Limpeza a cada 2h
AUDIT_RETENTION_DAYS=90                   # 3 meses de retenção

# ===== FRONTEND =====
SERVE_STATIC_FILES=true
STATIC_FILES_DIR=front/janus-angular/public

# Frontend otimizado
VITE_API_BASE_URL=http://localhost:8000
VITE_FEATURE_SSE=true
VITE_UX_METRICS_SAMPLING=1.0
VITE_SSE_RETRY_MAX_SECONDS=60            # Retry maior

# ===== BANCOS DE DADOS - APROVEITAR RECURSOS =====
# Neo4j - mais memória para graph database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_dbms_memory_heap_initial__size=4G   # 4GB heap inicial
NEO4J_dbms_memory_heap_max__size=8G      # 8GB heap máximo
NEO4J_dbms_memory_pagecache_size=4G       # 4GB page cache

# Qdrant - vetor database otimizado
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_OPTIMIZERS_CPU_THREADS=8          # Usar 8 threads para otimização

# MySQL - configuração para dados
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=janus
MYSQL_PASSWORD=janus_pass
MYSQL_DATABASE=janus_config
MYSQL_ROOT_PASSWORD=janus_root

# RabbitMQ - message broker
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=janus
RABBITMQ_PASSWORD=janus_pass
RABBITMQ_MANAGEMENT_PORT=15672

# ===== LLM POOL - OTIMIZAÇÃO FINAL =====
# Pool de LLMs quentes - aproveitar 64GB RAM
LLM_POOL_WARM_PROVIDERS=["ollama:llama3.1:8b","ollama:codellama:7b"]
LLM_POOL_MIN_SIZE=2                      # Manter 2 modelos sempre quentes
LLM_POOL_PRELOAD=true                   # Pré-carregar no startup

# ===== SEGURANÇA =====
AUTH_JWT_SECRET=your_strong_secret_key_here_change_me
AUTH_JWT_EXPIRES_SECONDS=7200            # 2h de sessão
PUBLIC_API_KEY=your_api_key_here        # Adicione se quiser proteção
CORS_ALLOW_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200","http://localhost:4201"]
