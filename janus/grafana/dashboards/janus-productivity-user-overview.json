{
  "title": "Janus Productivity by User",
  "tags": ["janus", "productivity", "user"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "bargauge",
      "title": "Requests per User",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "options": {"displayMode": "gradient"},
      "targets": [
        {"expr": "topk(10, sum by (user_id) (productivity_requests_user_total))", "refId": "A"}
      ]
    },
    {
      "type": "bargauge",
      "title": "Requests per User by Tool",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "options": {"displayMode": "gradient"},
      "targets": [
        {"expr": "topk(10, sum by (user_id,tool) (productivity_requests_user_total))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by User (req/s)",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (user_id) (rate(productivity_requests_user_total[5m]))", "refId": "A"}
      ]
    },
    {
      "type": "heatmap",
      "title": "Request Latency (seconds)",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (le) (rate(productivity_request_latency_seconds_bucket[5m]))", "refId": "A"}
      ],
      "options": {"legend": {"show": true}}
    }
  ]
}