############################################
# 4) Conhecimento: health, index, queries e validações
############################################
# @name knowledge_health
GET {{host}}{{api_v1_prefix}}/knowledge/health
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Knowledge health: 200 e JSON com status", function() {
  client.assert(response.status === 200);
  const body = response.body.json();
  client.assert(typeof body.status === "string");
});
%}

# @name knowledge_index
POST {{host}}{{api_v1_prefix}}/knowledge/index
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Indexação: 200 e inclui message/summary", function() {
  client.assert(response.status === 200);
  const body = response.body.json();
  client.assert(typeof body.message === "string");
  client.assert(typeof body.summary === "string");
});
%}

# @name entity_relationships_invalid_direction
GET {{host}}{{api_v1_prefix}}/knowledge/entity/Foo/relationships?direction=sideways&max_depth=2&limit=5&skip=0
Accept: application/problem+json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Relacionamentos com direction inválido: 422 problem+json", function() {
  client.assert(response.status === 422);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("problem+json"));
});
%}

# @name classes_implementations_missing_param
GET {{host}}{{api_v1_prefix}}/knowledge/classes/implementations
Accept: application/problem+json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Classes implementations sem protocolo: 422 problem+json", function() {
  client.assert(response.status === 422);
  client.assert((response.headers["content-type"] || "").toLowerCase().includes("problem+json"));
});
%}

# @name concepts_related_ok
POST {{host}}{{api_v1_prefix}}/knowledge/concepts/related
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

{
  "concept": "LangChain",
  "max_depth": 2,
  "limit": 5,
  "skip": 0
}

> {%
client.test("Conceitos relacionados: 200 e results array", function() {
  client.assert(response.status === 200);
  const body = response.body.json();
  client.assert(Array.isArray(body.results));
});
%}

# @name consolidate_batch_publish
POST {{host}}{{api_v1_prefix}}/knowledge/consolidate
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

{
  "mode": "batch",
  "limit": 5,
  "min_score": 0.0,
  "metadata": {"trigger": "e2e"}
}

> {%
client.test("Consolidate publish: 200 e mensagem esperada", function() {
  client.assert(response.status === 200);
  const body = response.body.json();
  client.assert(body.message === "Tarefa de consolidação publicada.");
  client.assert(typeof body.stats === "object");
});
%}

############################################
# 5) Finalização: Workers stop e status
############################################
# @name workers_stop_all
POST {{host}}{{api_v1_prefix}}/workers/stop-all
Content-Type: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Workers stop-all: 200 e JSON", function() {
  client.assert(response.status === 200);
});
%}

# @name workers_status_final
GET {{host}}{{api_v1_prefix}}/workers/status
Accept: application/json
X-Request-ID: {{correlation_id}}
User-Agent: Janus-HTTP-Test/{{client_version}}
Authorization: Bearer {{token}}

> {%
client.test("Workers status final: 200 e tracked >= 0", function() {
  client.assert(response.status === 200);
  const body = response.body.json();
  client.assert(typeof body.tracked === "number");
});
%}
