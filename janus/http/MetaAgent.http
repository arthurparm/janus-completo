###
# Meta-Agent API
# Coleção atualizada para verificar saúde, análise e heartbeat
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# Health Check
GET {{host}}{{api_v1_prefix}}/meta-agent/health
Accept: application/json

###
# Executar Análise Manual
POST {{host}}{{api_v1_prefix}}/meta-agent/analyze
Content-Type: application/json

###
# Relatório Mais Recente
GET {{host}}{{api_v1_prefix}}/meta-agent/report/latest
Accept: application/json

###
# Status do Heartbeat
GET {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/status
Accept: application/json

###
# Iniciar Heartbeat (Intervalo 60 min)
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/start
Content-Type: application/json

{
  "interval_minutes": 60
}

###
# Iniciar Heartbeat (Intervalo 30 min)
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/start
Content-Type: application/json

{
  "interval_minutes": 30
}

###
# Parar Heartbeat
POST {{host}}{{api_v1_prefix}}/meta-agent/heartbeat/stop
Content-Type: application/json
