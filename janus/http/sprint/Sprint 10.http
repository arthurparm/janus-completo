###
# SPRINT 10: Cérebro Híbrido e Resiliência de APIs
# Testes completos do LLM Manager com fallback automático e circuit breakers
###

@host = http://localhost:8000
@api_v1_prefix = /api/v1

###
# 1. Invocar LLM com Estratégia Local Only
# NOTA: Primeira invocação pode demorar 20-30s (carregamento do modelo)
POST {{host}}{{api_v1_prefix}}/llm/invoke
Content-Type: application/json

{
  "prompt": "Explique em uma frase o que é um circuit breaker",
  "role": "orchestrator",
  "priority": "local_only",
  "timeout_seconds": 45
}

###
# 2. Invocar LLM com Estratégia Fast and Cheap
POST {{host}}{{api_v1_prefix}}/llm/invoke
Content-Type: application/json

{
  "prompt": "Liste 3 vantagens de usar modelos de linguagem locais",
  "role": "orchestrator",
  "priority": "fast_and_cheap",
  "timeout_seconds": 30
}

###
# 3. Invocar LLM com Estratégia High Quality
POST {{host}}{{api_v1_prefix}}/llm/invoke
Content-Type: application/json

{
  "prompt": "Escreva um algoritmo recursivo para calcular o fatorial de um número",
  "role": "code_generator",
  "priority": "high_quality",
  "timeout_seconds": 60
}

###
# 4. Invocar LLM - Knowledge Curator Role
POST {{host}}{{api_v1_prefix}}/llm/invoke
Content-Type: application/json

{
  "prompt": "Resuma os principais conceitos de aprendizado de máquina",
  "role": "knowledge_curator",
  "priority": "fast_and_cheap",
  "timeout_seconds": 30
}

###
# 5. Obter Status do Cache de LLMs
GET {{host}}{{api_v1_prefix}}/llm/cache/status
Accept: application/json

###
# 6. Obter Status dos Circuit Breakers
GET {{host}}{{api_v1_prefix}}/llm/circuit-breakers
Accept: application/json

###
# 7. Listar Provedores Configurados
GET {{host}}{{api_v1_prefix}}/llm/providers
Accept: application/json

###
# 8. Health Check do Sistema de LLMs
GET {{host}}{{api_v1_prefix}}/llm/health
Accept: application/json

###
# 9. Invalidar Cache Completo
POST {{host}}{{api_v1_prefix}}/llm/cache/invalidate
Content-Type: application/json

###
# 10. Resetar Circuit Breaker de um Provedor
POST {{host}}{{api_v1_prefix}}/llm/circuit-breakers/openai/reset
Content-Type: application/json
