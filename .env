# Docker Compose Environment Variables
# Copied from janus/app/.env for interpolation in docker-compose.yml

# Docker daemon socket (Windows default). On Linux, use /var/run/docker.sock
DOCKER_SOCK=//./pipe/docker_engine

# Neo4j memory tuning (Docker Desktop friendly defaults)
NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# Database Credentials
MYSQL_ROOT_PASSWORD=janus_root
MYSQL_DATABASE=janus_config
MYSQL_USER=janus
MYSQL_PASSWORD=janus_pass

# Neo4j Credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# RabbitMQ Credentials
RABBITMQ_USER=janus
RABBITMQ_PASSWORD=janus_pass

# Grafana Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Supabase (Placeholder/Dev)
VITE_SUPABASE_ANON_KEY=placeholder_anon_key_for_dev
