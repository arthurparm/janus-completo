{
  "name": "janus-angular",
  "version": "0.5.44",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o --proxy-config proxy.conf.json",
    "start:tailscale": "ng serve -o --proxy-config proxy.tailscale.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint ./src --ext .ts --max-warnings 0",
    "lint:fix": "eslint ./src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "@angular/animations": "$@angular/animations",
    "@angular/common": "$@angular/common",
    "@angular/compiler": "$@angular/compiler",
    "@angular/compiler-cli": "$@angular/compiler-cli",
    "@angular/core": "$@angular/core",
    "@angular-devkit/core": {
      "ajv": "8.18.0"
    },
    "@angular/forms": "$@angular/forms",
    "@modelcontextprotocol/sdk": {
      "ajv": "8.18.0"
    },
    "@angular/platform-browser": "$@angular/platform-browser",
    "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic",
    "@angular/router": "$@angular/router",
    "rollup": "4.59.0"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.3.17",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/service-worker": "^20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/cytoscape": "^3.21.9",
    "@types/dompurify": "^3.0.5",
    "@types/highlight.js": "^9.12.4",
    "@types/marked": "^5.0.2",
    "@types/prismjs": "^1.26.5",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "dompurify": "^3.3.1",
    "firebase": "^12.7.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "ng2-charts": "^8.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.4.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.2",
    "@analogjs/vitest-angular": "^2.2.2",
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/angular": "^19.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.1",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
