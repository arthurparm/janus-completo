{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (s)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(janus_resilience_attempt_latency_seconds_bucket{operation=~\"$operation\"}[5m])) by (le, operation))",
          "legendFormat": "{{operation}} p95",
          "interval": ""
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p99 Latency (s)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(janus_resilience_attempt_latency_seconds_bucket{operation=~\"$operation\"}[5m])) by (le, operation))",
          "legendFormat": "{{operation}} p99",
          "interval": ""
        }
      ]
    },
    {
      "type": "row",
      "title": "Reliability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Error Rate (%)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (operation) (rate(janus_resilience_attempt_latency_seconds_count{operation=~\"$operation\", outcome=\"failure\"}[5m])) / sum by (operation) (rate(janus_resilience_attempt_latency_seconds_count{operation=~\"$operation\"}[5m]))",
          "legendFormat": "{{operation}} error rate",
          "interval": ""
        }
      ]
    },
    {
      "type": "stat",
      "title": "Current CB OPEN (0/1)",
      "id": 4,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (operation) (janus_resilience_circuit_state{operation=~\"$operation\", state=\"OPEN\"})",
          "legendFormat": "{{operation}} OPEN",
          "interval": ""
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CB Open Duration (s)",
      "id": 5,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (operation) (janus_resilience_open_time_seconds{operation=~\"$operation\"})",
          "legendFormat": "{{operation}} open secs",
          "interval": ""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["prometheus", "janus", "resilience", "circuit-breaker"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true
        },
        "label": "Prometheus datasource",
        "hide": 0
      },
      {
        "name": "operation",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "label": "Component/Operation",
        "query": "label_values(janus_resilience_attempt_latency_seconds_count, operation)",
        "current": {
          "selected": true,
          "text": "All",
          "value": ["$__all"]
        }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Janus - Component Resilience (p95/p99, Error rate, CB)",
  "uid": "janus-comp-resilience",
  "version": 1,
  "weekStart": ""
}